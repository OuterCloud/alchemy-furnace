// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// Enums
// ============================================================

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

enum RoleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum MessageRole {
  USER
  ASSISTANT
}

enum KnowledgeBaseType {
  REFINEMENT
  FILE
  URL
}

enum SourceType {
  PDF
  URL
  TEXT
  AUDIO
}

enum ProcessStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

// ============================================================
// Auth Models (NextAuth v5 compatible)
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  plan          Plan      @default(FREE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts   Account[]
  sessions   Session[]
  workspaces WorkspaceMember[]

  @@map("users")
}

model Account {
  provider          String
  providerAccountId String
  type              String
  access_token      String? @db.Text
  refresh_token     String? @db.Text
  id_token          String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  userId            String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ============================================================
// Workspace (Multi-tenant core)
// ============================================================

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  logoUrl   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members         WorkspaceMember[]
  roles           Role[]
  knowledgeBases  KnowledgeBase[]
  sources         SourceMaterial[]
  dataSources     DataSource[]

  @@map("workspaces")
}

model WorkspaceMember {
  userId      String
  workspaceId String
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@id([userId, workspaceId])
  @@map("workspace_members")
}

// ============================================================
// Role (Deployable Conversation Agent)
// ============================================================

model Role {
  id           String     @id @default(cuid())
  name         String
  description  String?    @db.Text
  systemPrompt String     @db.LongText
  examples     Json?
  metadata     Json?
  status            RoleStatus @default(DRAFT)
  isPublic          Boolean    @default(false)
  allowDataRequest  Boolean    @default(false)
  workspaceId       String
  createdById  String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workspace      Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  knowledgeBases RoleKnowledgeBase[]
  dataSources    RoleDataSource[]
  conversations  Conversation[]
  jobs           RefinementJob[]

  @@index([workspaceId])
  @@index([status])
  @@map("roles")
}

// ============================================================
// Knowledge Base + Chunks (RAG — workspace-level)
// ============================================================

model KnowledgeBase {
  id          String            @id @default(cuid())
  name        String
  description String?           @db.Text
  type        KnowledgeBaseType @default(REFINEMENT)
  sourceUrl   String?
  workspaceId String
  createdById String
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  workspace Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  chunks    KnowledgeChunk[]
  roles     RoleKnowledgeBase[]

  @@index([workspaceId])
  @@map("knowledge_bases")
}

model RoleKnowledgeBase {
  roleId          String
  knowledgeBaseId String
  attachedAt      DateTime @default(now())

  role          Role          @relation(fields: [roleId], references: [id], onDelete: Cascade)
  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@id([roleId, knowledgeBaseId])
  @@map("role_knowledge_bases")
}

model KnowledgeChunk {
  id              String   @id @default(cuid())
  knowledgeBaseId String
  content         String   @db.LongText
  qdrantId        String?
  createdAt       DateTime @default(now())

  knowledgeBase KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)

  @@index([knowledgeBaseId])
  @@map("knowledge_chunks")
}

// ============================================================
// Conversation + Messages
// ============================================================

model Conversation {
  id        String   @id @default(cuid())
  title     String?  @db.Text
  roleId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  role     Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([roleId])
  @@index([userId])
  @@map("conversations")
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String      @db.LongText
  imageUrls      String?     @db.LongText
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("messages")
}

// ============================================================
// Source Material (Raw input for refinement)
// ============================================================

model SourceMaterial {
  id          String        @id @default(cuid())
  type        SourceType
  title       String?
  content     String?       @db.LongText
  fileUrl     String?
  fileSize    Int?
  mimeType    String?
  status      ProcessStatus @default(PENDING)
  workspaceId String
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  workspace Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  jobs      RefinementJob[]

  @@index([workspaceId])
  @@map("source_materials")
}

// ============================================================
// Data Source (HTTP API tool for LLM function calling)
// ============================================================

model DataSource {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  description String?  @db.Text
  method      String   @default("GET")
  url         String   @db.Text
  headers     Json?
  paramSchema Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  roles     RoleDataSource[]

  @@index([workspaceId])
  @@map("data_sources")
}

model RoleDataSource {
  roleId       String
  dataSourceId String
  order        Int    @default(0)

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  dataSource DataSource @relation(fields: [dataSourceId], references: [id], onDelete: Cascade)

  @@id([roleId, dataSourceId])
  @@map("role_data_sources")
}

// ============================================================
// Refinement Job (Async LLM processing task)
// ============================================================

model RefinementJob {
  id          String        @id @default(cuid())
  sourceId    String
  roleId      String?
  instruction String?       @db.Text
  status      ProcessStatus @default(PENDING)
  progress    Int           @default(0)
  result      Json?
  error       String?       @db.Text
  createdById String
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  source SourceMaterial @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  role   Role?          @relation(fields: [roleId], references: [id])

  @@index([sourceId])
  @@index([status])
  @@map("refinement_jobs")
}

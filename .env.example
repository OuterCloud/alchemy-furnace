# =============================================================
# Application
# =============================================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# =============================================================
# Database (MySQL)
# =============================================================
DATABASE_URL="mysql://alchemy:alchemy_password@localhost:3306/alchemy_furnace"

# =============================================================
# Auth (NextAuth.js v5)
# =============================================================
AUTH_SECRET=your-auth-secret-min-32-chars  # run: openssl rand -base64 32

# WeChat OAuth
AUTH_WECHAT_ID=your-wechat-app-id
AUTH_WECHAT_SECRET=your-wechat-app-secret

# Feishu OAuth (register at https://open.feishu.cn)
AUTH_FEISHU_ID=your-feishu-app-id
AUTH_FEISHU_SECRET=your-feishu-app-secret

# =============================================================
# LLM (OpenAI-compatible API)
# =============================================================
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=sk-your-api-key
LLM_MODEL=gpt-4o

# =============================================================
# Redis (BullMQ + Cache)
# =============================================================
REDIS_URL=redis://localhost:6379

# =============================================================
# Qdrant (Vector Database)
# =============================================================
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# =============================================================
# File Storage (Cloudflare R2 / S3-compatible)
# =============================================================
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY_ID=your-access-key-id
STORAGE_SECRET_ACCESS_KEY=your-secret-access-key
STORAGE_BUCKET_NAME=alchemy-furnace
NEXT_PUBLIC_STORAGE_PUBLIC_URL=https://your-public-r2-domain.com
